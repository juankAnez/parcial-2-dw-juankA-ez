# =============================================
# EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores
# =============================================
PORT=3000
NODE_ENV=development

# =============================================
# SELECCIÓN DE MOTOR DE BASE DE DATOS
# Opciones: mysql | mssql
# =============================================
DB_ENGINE=mysql

# =============================================
# BASE DE DATOS - MySQL
# =============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=tu_password_mysql
MYSQL_DATABASE=parcial2

# =============================================
# BASE DE DATOS - SQL Server
# =============================================
SQLSERVER_HOST=172.19.252.171
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=tu_password_sa
SQLSERVER_DB=parcial2